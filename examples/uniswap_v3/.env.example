# Copy this file to .env and fill in your values.
# The script loads .env automatically via python-dotenv.

# --- Provider credentials ---

# Required when using --provider hypersync
BEARER_TOKEN=

# Required when using --provider rpc (or pass --rpc_url on the CLI)
RPC_URL=https://mainnet.gateway.tenderly.co

# --- ClickHouse (only needed with --database clickhouse) ---

CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=default
CLICKHOUSE_DATABASE=default
CLICKHOUSE_SECURE=false

# --- Iceberg (only needed with --database iceberg) ---

ICEBERG_NAMESPACE=default
